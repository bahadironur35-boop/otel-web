generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReservationStatus {
  NEW
  CONFIRMED
  PAYMENT_PENDING
  CANCELLED
}

enum RoomStatus {
  READY
  CLEANING
  MAINTENANCE
  EXTRA_BED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ChannelStatus {
  SYNCED
  DELAYED
  ACTION_REQUIRED
}

enum ProviderType {
  CHANNEX
  HOTELRUNNER
  SITEMINDER
  DIRECT_OTA
  MANUAL_CSV
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONNECTED
  DEGRADED
  DISCONNECTED
}

enum SyncDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

enum SyncState {
  PENDING
  SUCCESS
  FAILED
}

enum ComplianceStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  NOT_APPLICABLE
}

enum PaymentProvider {
  MANUAL
  IYZICO
  PAYTR
  BANK_POS
}

enum PaymentStatus {
  CREATED
  LINK_SENT
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum GuestStatus {
  STANDARD
  VIP
  WATCHLIST
}

enum StayStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

enum PhysicalRoomStatus {
  READY
  OCCUPIED
  CLEANING
  MAINTENANCE
  OUT_OF_SERVICE
}

model Hotel {
  id            String                @id @default(cuid())
  name          String
  slug          String                @unique
  city          String
  country       String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  rooms         RoomType[]
  reservations  Reservation[]
  tasks         Task[]
  channels      Channel[]
  providers     IntegrationProvider[]
  connections   ChannelConnection[]
  roomMappings  RoomMapping[]
  syncLogs      SyncLog[]
  compliance    ComplianceItem[]
  payments      Payment[]
  guests        Guest[]
  physicalRooms PhysicalRoom[]
  stays         Stay[]
}

model RoomType {
  id            String         @id @default(cuid())
  hotelId       String
  hotel         Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name          String
  capacity      String
  nightlyRate   Int
  currency      String         @default("TRY")
  status        RoomStatus     @default(READY)
  inventory     Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reservations  Reservation[]
  roomMappings  RoomMapping[]
  physicalRooms PhysicalRoom[]
}

model Reservation {
  id          String            @id @default(cuid())
  hotelId     String
  hotel       Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomTypeId  String
  roomType    RoomType          @relation(fields: [roomTypeId], references: [id])
  guestName   String
  guestEmail  String?
  checkIn     DateTime
  checkOut    DateTime
  guests      Int               @default(2)
  channel     String            @default("Web sitesi")
  status      ReservationStatus @default(NEW)
  totalAmount Int
  currency    String            @default("TRY")
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  payments    Payment[]
  guestId     String?
  guest       Guest?            @relation(fields: [guestId], references: [id], onDelete: SetNull)
  stay        Stay?
}

model Task {
  id        String       @id @default(cuid())
  hotelId   String
  hotel     Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  title     String
  owner     String
  dueAt     DateTime
  priority  TaskPriority @default(MEDIUM)
  done      Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Channel {
  id        String        @id @default(cuid())
  hotelId   String
  hotel     Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name      String
  status    ChannelStatus @default(SYNCED)
  inventory Int           @default(0)
  alert     String        @default("Sorun yok")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([hotelId, name])
}

model IntegrationProvider {
  id                String              @id @default(cuid())
  hotelId           String
  hotel             Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  type              ProviderType
  name              String
  status            IntegrationStatus   @default(NOT_CONFIGURED)
  externalAccountId String?
  lastTestedAt      DateTime?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  connections       ChannelConnection[]
  roomMappings      RoomMapping[]
  syncLogs          SyncLog[]

  @@unique([hotelId, type])
}

model ChannelCatalog {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  market            String
  category          String
  defaultCurrency   String?
  supportsInventory Boolean             @default(true)
  supportsRates     Boolean             @default(true)
  supportsBookings  Boolean             @default(true)
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  connections       ChannelConnection[]
}

model ChannelConnection {
  id                String              @id @default(cuid())
  hotelId           String
  hotel             Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  providerId        String
  provider          IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  channelCatalogId  String
  channelCatalog    ChannelCatalog      @relation(fields: [channelCatalogId], references: [id], onDelete: Restrict)
  externalChannelId String?
  enabled           Boolean             @default(false)
  status            IntegrationStatus   @default(NOT_CONFIGURED)
  lastSyncedAt      DateTime?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  syncLogs          SyncLog[]

  @@unique([hotelId, channelCatalogId])
}

model RoomMapping {
  id                 String              @id @default(cuid())
  hotelId            String
  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  providerId         String
  provider           IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  roomTypeId         String
  roomType           RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  externalRoomTypeId String
  externalRatePlanId String?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([providerId, roomTypeId])
}

model SyncLog {
  id                  String               @id @default(cuid())
  hotelId             String
  hotel               Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  providerId          String?
  provider            IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  channelConnectionId String?
  channelConnection   ChannelConnection?   @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  direction           SyncDirection
  resource            String
  state               SyncState
  recordsCount        Int                  @default(0)
  message             String
  externalReference   String?
  createdAt           DateTime             @default(now())

  @@index([hotelId, createdAt])
}

model ComplianceItem {
  id        String           @id @default(cuid())
  hotelId   String
  hotel     Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  code      String
  title     String
  category  String
  status    ComplianceStatus @default(NOT_STARTED)
  notes     String?
  dueDate   DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([hotelId, code])
}

model Payment {
  id                  String          @id @default(cuid())
  hotelId             String
  hotel               Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservationId       String
  reservation         Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider            PaymentProvider @default(MANUAL)
  status              PaymentStatus   @default(CREATED)
  amount              Int
  currency            String          @default("TRY")
  paymentLink         String?
  externalTransaction String?
  failureReason       String?
  expiresAt           DateTime?
  paidAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([hotelId, status])
  @@index([reservationId, createdAt])
}

model Guest {
  id             String        @id @default(cuid())
  hotelId        String
  hotel          Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  fullName       String
  email          String?
  phone          String?
  nationality    String?
  identityNumber String?
  passportNumber String?
  status         GuestStatus   @default(STANDARD)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reservations   Reservation[]
  stays          Stay[]

  @@index([hotelId, fullName])
  @@index([hotelId, email])
}

model PhysicalRoom {
  id         String             @id @default(cuid())
  hotelId    String
  hotel      Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomTypeId String
  roomType   RoomType           @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  number     String
  floor      String?
  status     PhysicalRoomStatus @default(READY)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  stays      Stay[]

  @@unique([hotelId, number])
  @@index([roomTypeId, status])
}

model Stay {
  id               String       @id @default(cuid())
  hotelId          String
  hotel            Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservationId    String       @unique
  reservation      Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guestId          String
  guest            Guest        @relation(fields: [guestId], references: [id], onDelete: Restrict)
  physicalRoomId   String
  physicalRoom     PhysicalRoom @relation(fields: [physicalRoomId], references: [id], onDelete: Restrict)
  status           StayStatus   @default(RESERVED)
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  expectedCheckIn  DateTime
  expectedCheckOut DateTime
  adults           Int          @default(1)
  children         Int          @default(0)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([hotelId, status])
  @@index([physicalRoomId, status])
}
